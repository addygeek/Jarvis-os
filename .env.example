# =============================================================================
# JarvisOS environment variables
# Copy to .env at the repo root: cp .env.example .env
# Backend keys below match backend/src/config.ts (dotenv at repo root).
# Other sections are used by voice, documents, and frontend packages.
# =============================================================================

# -----------------------------------------------------------------------------
# Backend API (@jarvisos/backend) — backend/src/config.ts
# -----------------------------------------------------------------------------
# HTTP port for the Express API
PORT=3847

# development | production
NODE_ENV=development

# SQLite database file (MemoryStore auto-applies database/schema.sql)
DATABASE_PATH=./database/jarvisos.db

# Multipart upload destination (POST /api/files/upload)
UPLOADS_DIR=./data/uploads

# Comma-separated CORS origins (defaults include localhost:5173 and :3000 if unset)
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# -----------------------------------------------------------------------------
# Ollama — reasoning layer (backend + agent + documents)
# -----------------------------------------------------------------------------
# Backend / agent use OLLAMA_BASE_URL:
OLLAMA_BASE_URL=http://127.0.0.1:11434

# documents/ summarize module uses OLLAMA_HOST (same host, different name):
OLLAMA_HOST=http://127.0.0.1:11434

# Model tag from `ollama pull` (see models/README.md)
OLLAMA_MODEL=gemma4:e4b

# -----------------------------------------------------------------------------
# Voice — speech-to-text (@jarvisos/voice)
# -----------------------------------------------------------------------------
# Deepgram API key — primary STT engine (get one free at https://console.deepgram.com)
DEEPGRAM_API_KEY=

# whisper.cpp CLI binary name or absolute path (fallback when DEEPGRAM_API_KEY is not set)
WHISPER_CLI=whisper

# Optional GGML model path for whisper.cpp (-m flag)
WHISPER_MODEL_PATH=

# -----------------------------------------------------------------------------
# Documents — PDF pipeline (@jarvisos/documents)
# -----------------------------------------------------------------------------
# Python interpreter for PyMuPDF fallback extraction
PYTHON=python3

# -----------------------------------------------------------------------------
# Frontend — Electron + Vite (@jarvisos/frontend)
# -----------------------------------------------------------------------------
# Backend URL for production / packaged UI builds.
# Vite dev uses the proxy in frontend/vite.config.ts (same-origin /api) — leave unset or any value.
VITE_API_URL=http://127.0.0.1:3847

# Optional override for scripts/demo.sh and Electron health checks
# JARVIS_API_URL=http://localhost:3847

# Dev only: Electron auto-starts the API when running electron:dev
# JARVIS_SPAWN_BACKEND=1
