{
  "name": "@jarvisos/tools",
  "version": "0.1.0",
  "private": true,
  "description": "JarvisOS macOS tool layer for agent execution",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "postinstall": "npm rebuild better-sqlite3 2>/dev/null || true"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.10",
    "@types/pdf-parse": "^1.1.4",
    "@vitest/coverage-v8": "^3.0.5",
    "typescript": "^5.8.2",
    "vitest": "^3.0.5"
  }
}
