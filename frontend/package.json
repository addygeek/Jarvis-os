{
  "name": "@jarvisos/frontend",
  "version": "0.1.0",
  "private": true,
  "description": "JarvisOS Electron + React desktop UI",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && npm run electron:build",
    "typecheck": "tsc -b --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "preview": "vite preview",
    "electron:build": "tsc -p tsconfig.electron.json",
    "electron:dev": "npm run electron:build && concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:package": "npm run build && electron-builder --mac dmg",
    "package": "npm run electron:package"
  },
  "dependencies": {
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^26.0.12",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "wait-on": "^8.0.3"
  },
  "build": {
    "electronVersion": "33.3.1",
    "appId": "com.jarvisos.app",
    "productName": "JarvisOS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": ["dmg"]
    }
  }
}
